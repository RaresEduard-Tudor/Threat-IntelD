# Copy this file to .env and fill in your values before running locally.

# Google Safe Browsing v4 API key
# Get one at: https://developers.google.com/safe-browsing/v4/get-started
# If not set, the Safe Browsing check is skipped (no error).
GOOGLE_SAFE_BROWSING_API_KEY=your_key_here

# VirusTotal v3 API key
# Get a free key at: https://www.virustotal.com/gui/join-us
# If not set, the VirusTotal check is skipped (no error).
VIRUSTOTAL_API_KEY=your_key_here

# AbuseIPDB v2 API key — used for IP reputation checks
# Get a free key at: https://www.abuseipdb.com/register
# If not set, the IP reputation check is skipped (no error).
ABUSEIPDB_API_KEY=your_key_here

# Comma-separated list of allowed frontend origins for CORS.
# Use * for local development only.
# In production, set to your Vercel domain: https://your-app.vercel.app
ALLOWED_ORIGIN=*
